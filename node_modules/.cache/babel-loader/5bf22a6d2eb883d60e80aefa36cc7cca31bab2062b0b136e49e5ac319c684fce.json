"param","JSON","stringify","eventoJson","encodeURIComponent","$router","push","path","query","evento","mounted"],"sources":["/home/marco-peixoto/myticket/src/views/MenuView.vue"],"sourcesContent":["<template>\n  <div id=\"menu-view\">\n    <h1>Eventos Disponíveis</h1>\n    <div id=\"scroll-horizontal\">\n      <div id=\"card-content\" v-for=\"evento in listaMenuEventos\" :key=\"evento.id\">\n        <img :src=\"evento.foto\" class=\"card-foto\" />\n        <div id=\"card-coluna\">\n          <p id=\"nome-content\">{{ evento.nome }}</p>\n          <p id=\"preco-content\">R$ {{ evento.valor }},00</p>\n          <p id=\"descricao-content\">{{ evento.descricao }}</p>\n          <button @click=\"selecionarEvento(evento)\">Selecionar</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuEventos: [],\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"https://api-myticket.onrender.com/menu\");\n      const dados = await response.json();\n      this.listaMenuEventos = dados.eventos;\n    },\n    selecionarEvento(eventoSelecionado) {\n      const param = JSON.stringify(eventoSelecionado);\n      const eventoJson = encodeURIComponent(param);\n      this.$router.push({ path: \"/config-pedido\", query: { evento: eventoJson } });\n    },\n  },\n  mounted() {\n    this.consultarMenu();\n  },\n};\n</script>\n<style scoped>\n@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');\n\n#menu-view {\n  font-family: 'Poppins', sans-serif;\n  padding: 20px;\n  background-color: #0f0f0f;\n  min-height: 100vh;\n}\n\nh1 {\n  color: #e2e8f0;\n  font-size: 28px;\n  margin-bottom: 24px;\n}\n\n#scroll-horizontal {\n  display: flex;\n  overflow-x: auto;\n  gap: 20px;\n  padding-bottom: 16px;\n}\n\n#scroll-horizontal::-webkit-scrollbar {\n  height: 6px;\n}\n#scroll-horizontal::-webkit-scrollbar-thumb {\n  background: #7c3aed;\n  border-radius: 10px;\n}\n\n#card-content {\n  min-width: 260px;\n  max-width: 260px;\n  background: #1a1a2e;\n  border-radius: 12px;\n  overflow: hidden;\n  border: 1px solid #2d2d4e;\n  flex-shrink: 0;\n  display: flex;\n  flex-direction: column;\n  transition: transform 0.2s, border-color 0.2s;\n}\n\n#card-content:hover {\n  transform: translateY(-4px);\n  border-color: #7c3aed;\n}\n\n.card-foto {\n  width: 100%;\n  height: 160px;\n  object-fit: cover;\n}\n\n#card-coluna {\n  padding: 14px;\n  display: flex;\n  flex-direction: column;\n  flex-grow: 1;\n}\n\n#nome-content {\n  font-size: 16px;\n  font-weight: 700;\n  color: #e2e8f0;\n  margin: 0 0 6px 0;\n  white-space: normal;\n}\n\n#preco-content {\n  font-size: 22px;\n  font-weight: 700;\n  color: #a78bfa;\n  margin: 0 0 8px 0;\n}\n\n#descricao-content {\n  font-size: 13px;\n  color: #94a3b8;\n  margin: 0 0 14px 0;\n  display: -webkit-box;\n  -webkit-line-clamp: 4;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  flex-grow: 1;\n}\n\n#card-coluna button {\n  padding: 10px;\n  width: 100%;\n  border-radius: 8px;\n  border: none;\n  color: #fff;\n  background-color: #7c3aed;\n  cursor: pointer;\n  font-family: 'Poppins', sans-serif;\n  font-weight: 600;\n  font-size: 14px;\n  transition: background-color 0.2s;\n}\n\n#card-coluna button:hover {\n  background-color: #5b21b6;\n}\n</style>"],"mappings":";;;;;;AAiBA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAI,WAAJA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,gBAAgB,EAAE;IACpB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACDC,aAAa,WAAbA,aAAaA,CAAA,EAAG;MAAA,IAAAC,KAAA;MAAA,OAAAC,iBAAA,cAAAC,YAAA,GAAAC,CAAA,UAAAC,QAAA;QAAA,IAAAC,QAAA,EAAAC,KAAA;QAAA,OAAAJ,YAAA,GAAAK,CAAA,WAAAC,QAAA;UAAA,kBAAAA,QAAA,CAAAC,CAAA;YAAA;cAAAD,QAAA,CAAAC,CAAA;cAAA,OACGC,KAAK,CAAC,wCAAwC,CAAC;YAAA;cAAhEL,QAAO,GAAAG,QAAA,CAAAG,CAAA;cAAAH,QAAA,CAAAC,CAAA;cAAA,OACOJ,QAAQ,CAACO,IAAI,CAAC,CAAC;YAAA;cAA7BN,KAAI,GAAAE,QAAA,CAAAG,CAAA;cACVX,KAAI,CAACH,gBAAe,GAAIS,KAAK,CAACO,OAAO;YAAA;cAAA,OAAAL,QAAA,CA