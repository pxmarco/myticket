{"ast":null,"code":"export default {\n  name: \"NavBarComponent\"\n};","map":{"version":3,"names":["name"],"sources":["/home/marco-peixoto/myticket/src/components/NavBarComponent.vue"],"sourcesContent":["<template>\n  <div>\n    <nav id=\"nav\">\n      <router-link to=\"/\" id=\"logo-url\">\n        <img src=\"@/assets/logo.png\" id=\"logo\" alt=\"MyTicket\" />\n      </router-link>\n      <div id=\"nav-links\">\n        <router-link to=\"/menu\">Eventos</router-link>\n        <router-link to=\"/pedidos\">Ingressos</router-link>\n      </div>\n    </nav>\n  </div>\n</template>\n<script>\nexport default {\n  name: \"NavBarComponent\",\n};\n</script>\n<style scoped>\n@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');\n\n#nav {\n  background-color: #0d0d0d;\n  border-bottom: 3px solid #7c3aed;\n  padding: 14px 40px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-family: 'Poppins', sans-serif;\n}\n\n#logo-url {\n  text-decoration: none;\n}\n\n#logo {\n  width: 130px;\n  height: 130px;\n  object-fit: contain;\n  transition: 0.2s;\n}\n\n#logo:hover {\n  width: 100px;\n  height: 100px;\n}\n\n#nav-links {\n  display: flex;\n  gap: 30px;\n}\n\n#nav a {\n  color: #e2e8f0;\n  text-decoration: none;\n  font-size: 16px;\n  font-weight: 600;\n  transition: color 0.2s;\n}\n\n#nav a:hover,\n#nav a.router-link-active {\n  color: #a78bfa;\n}\n</style>"],"mappings":"AAcA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}